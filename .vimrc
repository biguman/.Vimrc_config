set number
syntax on
set showmatch
set matchtime=2
set ruler
set incsearch                  " Shows matches as you type
set ignorecase
set smartcase
set smartindent     " Enable smarter indentation for programming languages
set tabstop=4       " Number of spaces that a <Tab> counts for
set shiftwidth=4    " Number of spaces for each indentation level
set expandtab       " Convert tabs to spaces
set softtabstop=4
set noswapfile
set clipboard=unnamed
set backspace=indent,eol,start
set hlsearch
set scrolloff=8
